{
  "version": 1,
  "sdk_version": "0.21.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://xqbbknydwgdpypdbelbm.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "rothme-mcp",
      "version": "0.1.0",
      "title": "ROTHME"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the ROTHME user identity for the current OAuth session.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_weekly_reports",
        "title": "List weekly reports",
        "description": "List the signed-in ROTHME user's saved weekly business reports (id, week_start, created_at), newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_weekly_report",
        "title": "Get weekly report",
        "description": "Fetch the full payload of a single weekly report owned by the signed-in ROTHME user, by report id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Report id from list_weekly_reports."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
